// --- Gemini API Helper ---
const apiKey = "";

const generateWithGemini = async (prompt) => {
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
  const payload = {
    contents: [{ parts: [{ text: prompt }] }],
    systemInstruction: { parts: [{ text: "You are an expert urban planner and regional strategist helping develop the Negev region in Israel. Respond in professional Hebrew. Do not use markdown formatting like bolding with asterisks, just use plain text with bullet points or numbers." }] }
  };

  for (let i = 0; i < 5; i++) {
    try {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      if (!res.ok) throw new Error('API Error');
      const data = await res.json();
      return data.candidates?.[0]?.content?.parts?.[0]?.text || "לא התקבלה תשובה מהמודל.";
    } catch (err) {
      if (i === 4) return "אירעה שגיאה בחיבור ל-AI. אנא נסה שנית מאוחר יותר.";
      await new Promise(r => setTimeout(r, Math.pow(2, i) * 1000));
    }
  }
};

