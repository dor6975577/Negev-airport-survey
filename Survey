            <h2 className="text-xl font-bold mb-6">כניסת מנהל מערכת</h2>
            <input type="password" placeholder="הזן סיסמה" className="w-full p-3 border rounded-lg mb-4 text-center text-lg focus:ring-2 focus:ring-blue-500 outline-none" value={adminCodeInput} onChange={(e) => setAdminCodeInput(e.target.value)} onKeyDown={(e) => { if(e.key === 'Enter') { if(adminCodeInput === appConfig.adminPassword) { setView('admin_dashboard'); setAdminError(''); setAdminCodeInput(''); } else { setAdminError('סיסמה שגויה'); } } }} />
            {adminError && <p className="text-red-500 mb-4 font-medium">{adminError}</p>}
            <button onClick={() => { if(adminCodeInput === appConfig.adminPassword) { setView('admin_dashboard'); setAdminError(''); setAdminCodeInput(''); } else { setAdminError('סיסמה שגויה'); } }} className="w-full text-white py-3 rounded-lg font-bold transition hover:brightness-110 shadow" style={{ backgroundColor: appConfig.primaryColor }}>היכנס</button>
          </div>
        )}

        {view === 'admin_dashboard' && (
          <AdminDashboard appConfig={appConfig} setAppConfig={setAppConfig} cities={cities} setCities={setCities} programs={programs} setPrograms={setPrograms} responses={responses} exportToXLSX={exportToXLSX} deleteResponse={deleteResponse} saveSettings={saveSettingsToCloud} tab={adminTab} setTab={setAdminTab} confirmAction={confirmAction} />
        )}
      </main>

      {/* Custom Confirm Dialog Modal */}
      {confirmDialog.isOpen && (
        <div className="fixed inset-0 bg-slate-900/50 z-[9999] flex items-center justify-center p-4 backdrop-blur-sm">
          <div className="bg-white rounded-2xl p-6 max-w-sm w-full shadow-2xl" dir="rtl">
            <h3 className="text-xl font-bold mb-3 text-slate-800">הודעת מערכת</h3>
            <p className="text-slate-600 mb-6">{confirmDialog.message}</p>
            <div className="flex gap-3 justify-end">
              {confirmDialog.isInfo ? (
                 <button onClick={closeConfirm} className="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold transition">אישור, הבנתי</button>
              ) : (
                 <>
                   <button onClick={closeConfirm} className="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium transition">ביטול</button>
                   <button onClick={executeConfirm} className="px-4 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg font-medium transition">כן, בצע</button>
                 </>
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

// --- Survey Form Component ---
function SurveyForm({ appConfig, surveyData, setSurveyData, cities, programs, onSubmit }) {
  const [activeRank, setActiveRank] = useState(null); // 0 to 4
  const [aiFeedback, setAiFeedback] = useState('');
  const [isGeneratingAi, setIsGeneratingAi] = useState(false);
  const [pois, setPois] = useState([]);
  const [isFetchingPois, setIsFetchingPois] = useState(false);
  const [loadedCategoriesDisplay, setLoadedCategoriesDisplay] = useState('');

  const cityObj = cities.find(c => c.id === surveyData.cityId);
  const mapCenterLat = cityObj?.lat || 31.2518;
  const mapCenterLng = cityObj?.lng || 34.7913;

  // Fetch POIs when active rank changes
  useEffect(() => {
    if (activeRank === null) {
      setPois([]);
      setLoadedCategoriesDisplay('');
      return;
    }

    const progId = surveyData.selectedPrograms[activeRank]?.programId;
    const prog = programs.find(p => p.id === progId);
    
    if (!prog || (!prog.poiCategory && !prog.poiCategory2)) {
      setPois([]);
      setLoadedCategoriesDisplay('');
      return;
    }

    const catObj1 = POI_CATEGORIES.find(c => c.id === prog.poiCategory);
    const catObj2 = POI_CATEGORIES.find(c => c.id === prog.poiCategory2);

    if (!catObj1?.tags && !catObj2?.tags) {
      setPois([]);
      setLoadedCategoriesDisplay('');
      return;
    }

    // Set display text for the loader toast
    const labels = [];
    if (catObj1?.tags) labels.push(catObj1.label);
    if (catObj2?.tags) labels.push(catObj2.label);
    setLoadedCategoriesDisplay(labels.join(' + '));

    let isMounted = true;
    const fetchPoisFromOSM = async () => {
      setIsFetchingPois(true);
      setPois([]); 
      
      try {
        const radiusMeters = 15000; // ~15km radius
        let queryNodes = '';
        
        // Build query parts based on selected categories
        if (catObj1?.tags) queryNodes += `nwr${catObj1.tags}(around:${radiusMeters},${mapCenterLat},${mapCenterLng});`;
        if (catObj2?.tags) queryNodes += `nwr${catObj2.tags}(around:${radiusMeters},${mapCenterLat},${mapCenterLng});`;

        if (!queryNodes) return;

        // Wrap the multiple parts in (...) for a Union query in Overpass
        const query = `[out:json][timeout:15];(${queryNodes});out center;`;
        const url = `https://overpass-api.de/api/interpreter?data=${encodeURIComponent(query)}`;
        
        const res = await fetch(url);
        if (!res.ok) throw new Error('Network response was not ok');
        const data = await res.json();
        
        if (!isMounted) return;

        // Extract and map data, attaching the PROGRAM'S color
        const fetchedPois = data.elements.map(e => ({
          lat: e.center ? e.center.lat : e.lat,
          lng: e.center ? e.center.lon : e.lon,
          name: e.tags?.['name:he'] || e.tags?.name || 'נקודת עניין',
          color: prog.color || appConfig.primaryColor // Inherit color!
        })).filter(p => p.lat && p.lng);

        setPois(fetchedPois);
      } catch (err) {
        console.error("Error fetching POIs from OSM:", err);
      } finally {
        if (isMounted) setIsFetchingPois(false);
      }
    };

    fetchPoisFromOSM();

    return () => { isMounted = false; };
  }, [activeRank, surveyData.selectedPrograms[activeRank]?.programId, mapCenterLat, mapCenterLng, programs, appConfig.primaryColor]);


  const handleProgramSelect = (index, programId) => {
    const newSelected = [...surveyData.selectedPrograms];
    const prog = programs.find(p => p.id === programId);
    
    if (newSelected[index].programId !== programId) {
      newSelected[index] = { programId, lat: null, lng: null, areaSqm: prog ? prog.minArea : 0, paramValue: prog ? prog.minParam : 0 };
    }
    setSurveyData({ ...surveyData, selectedPrograms: newSelected });
  };

  const handleUpdateProgramParams = (index, field, value) => {
    const newSelected = [...surveyData.selectedPrograms];
    newSelected[index] = { ...newSelected[index], [field]: value };
    setSurveyData({ ...surveyData, selectedPrograms: newSelected });
  };

  const handleMapClick = (lat, lng) => {
    if (activeRank !== null && surveyData.selectedPrograms[activeRank].programId) {
      const newSelected = [...surveyData.selectedPrograms];
      newSelected[activeRank] = { ...newSelected[activeRank], lat, lng };
      setSurveyData({ ...surveyData, selectedPrograms: newSelected });
      setActiveRank(null);
    }
  };

  const handleGenerateAiFeedback = async () => {
    setIsGeneratingAi(true);
    const cityName = cities.find(c => c.id === surveyData.cityId)?.name || '';
    const selectedDetails = surveyData.selectedPrograms.map((p, i) => {
      const prog = programs.find(pr => pr.id === p.programId);
      return `${i+1}. ${prog?.name} (${p.areaSqm} מ"ר, ${p.paramValue} ${prog?.paramName})`;
    }).join('\n');

    const prompt = `אני ${surveyData.role} של העיר ${cityName}. במסגרת תכנון שדה התעופה החדש בנגב, בחרתי את 5 הפרוגרמות הבאות שיוקמו סמוך לעיר שלי:\n${selectedDetails}\n\nכתוב פסקה אחת קצרה (עד 4 משפטים), מקצועית ומעוררת השראה, המנתחת כיצד תמהיל זה יתרום לפיתוח הכלכלי והחברתי של ${cityName}. אל תוסיף הקדמות, פשוט ספק את הניתוח.`;

    const response = await generateWithGemini(prompt);
    setAiFeedback(response);
    setIsGeneratingAi(false);
  };

  const isFormValid = surveyData.name && surveyData.role && surveyData.cityId && surveyData.selectedPrograms.every(p => p.programId && p.lat && p.lng);

  return (
    <div className="flex flex-col-reverse lg:flex-row gap-8 items-start">
      <div className="w-full lg:w-5/12 space-y-6 shrink-0 relative z-20">
        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
          <h2 className="text-xl font-bold mb-4 border-b pb-2">1. פרטים אישיים</h2>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-slate-700 mb-1">שם מלא</label>
              <input type="text" value={surveyData.name} onChange={e => setSurveyData({...surveyData, name: e.target.value})} className="w-full p-2.5 border rounded-lg bg-slate-50 focus:bg-white focus:ring-2 outline-none transition" style={{ '--tw-ring-color': appConfig.primaryColor }} placeholder="ישראל ישראלי" />
            </div>
            <div>
              <label className="block text-sm font-medium text-slate-700 mb-1">תפקיד</label>
              <input type="text" value={surveyData.role} onChange={e => setSurveyData({...surveyData, role: e.target.value})} className="w-full p-2.5 border rounded-lg bg-slate-50 focus:bg-white focus:ring-2 outline-none transition" style={{ '--tw-ring-color': appConfig.primaryColor }} placeholder="ראש מועצה / מהנדס עיר" />
            </div>
          </div>
          <div className="mt-4">
            <label className="block text-sm font-medium text-slate-700 mb-1">בחר/י רשות מקומית</label>
            <select value={surveyData.cityId} onChange={e => setSurveyData({...surveyData, cityId: e.target.value})} className="w-full p-2.5 border rounded-lg bg-slate-50 focus:bg-white focus:ring-2 outline-none transition font-medium" style={{ '--tw-ring-color': appConfig.primaryColor }}>
              <option value="">-- בחר רשות מהרשימה --</option>
              {cities.map(c => ( <option key={c.id} value={c.id}>{c.name}</option> ))}
            </select>
          </div>
        </div>

        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 relative">
          <div className="flex justify-between items-center mb-4 border-b pb-2">
            <h2 className="text-xl font-bold">2. דירוג ומיקום פרוגרמות</h2>
            <span className="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded-full font-semibold">5 נדרשים</span>
          </div>
          <p className="text-sm text-slate-600 mb-6">אנא בחר את 5 הפרוגרמות שהכי חשוב לך שיהיו בתחום הרשות שלך, ומקם אותן על גבי המפה הכללית. השטח המוגדר ישנה את גודל ההשפעה על המפה!</p>

          <div className="space-y-5 relative">
            {[0, 1, 2, 3, 4].map(index => {
              const selectedP = surveyData.selectedPrograms[index];
              const progData = programs.find(p => p.id === selectedP.programId);
              const isActive = activeRank === index;
              const hasPlaced = selectedP.lat !== null;
              const disabledProgIds = surveyData.selectedPrograms.map((sp, i) => i !== index ? sp.programId : null).filter(Boolean);
              const zIndexValue = 50 - index;

              return (
                <div key={index} className={`p-4 rounded-xl border-2 transition-all relative ${isActive ? 'shadow-md scale-[1.02]' : 'bg-slate-50 border-slate-100'}`} style={{ borderColor: isActive ? (progData?.color || appConfig.primaryColor) : '', zIndex: zIndexValue }}>
                  <div className="flex flex-col md:flex-row gap-3 items-start md:items-center">
                    <div className="flex-1 w-full">
                      <label className="text-xs font-bold text-slate-500 mb-1 flex items-center gap-1"><span className="w-5 h-5 rounded-full text-xs text-white flex items-center justify-center font-bold" style={{ backgroundColor: progData?.color || '#cbd5e1' }}>{index+1}</span> עדיפות {index + 1}</label>
                      <ProgramSelect programs={programs} selectedId={selectedP.programId} onChange={(val) => handleProgramSelect(index, val)} disabledPrograms={disabledProgIds} />
                    </div>
                    <button onClick={() => setActiveRank(isActive ? null : index)} disabled={!selectedP.programId} className={`w-full md:w-auto mt-2 md:mt-6 px-4 py-3 rounded-lg text-sm font-bold flex items-center justify-center gap-2 transition shadow-sm`} style={{ backgroundColor: !selectedP.programId ? '#e2e8f0' : (hasPlaced && !isActive ? '#dcfce7' : (isActive ? (progData?.color || appConfig.primaryColor) : '#f1f5f9')), color: !selectedP.programId ? '#94a3b8' : (hasPlaced && !isActive ? '#166534' : (isActive ? '#ffffff' : '#475569')) }}>
                      <MapPin className="w-4 h-4" />
                      {hasPlaced && !isActive ? 'שנה מיקום' : (isActive ? 'לחץ במפה...' : 'מקם במפה')}
                    </button>
                  </div>

                  {selectedP.programId && progData && (
                    <div className="mt-4 bg-white p-4 rounded-xl border border-slate-200 shadow-sm space-y-5">
                      <div>
                        <div className="flex justify-between text-xs text-slate-600 mb-2"><span className="font-bold">שטח מבוקש (מ"ר)</span><span className="font-bold text-lg" style={{ color: progData.color }}>{selectedP.areaSqm.toLocaleString()} מ"ר</span></div>
                        <input type="range" min={progData.minArea} max={progData.maxArea} step={1000} value={selectedP.areaSqm} onChange={(e) => handleUpdateProgramParams(index, 'areaSqm', Number(e.target.value))} className="w-full h-2.5 bg-slate-200 rounded-lg appearance-none cursor-pointer" style={{ accentColor: progData.color }} />
                        <div className="flex justify-between text-xs text-slate-400 mt-1 font-medium"><span>{progData.minArea.toLocaleString()}</span><span>{progData.maxArea.toLocaleString()}</span></div>
                      </div>
                      {progData.paramName && (
                        <div>
                          <div className="flex justify-between text-xs text-slate-600 mb-2"><span className="font-bold">{progData.paramName}</span><span className="font-bold text-lg" style={{ color: progData.color }}>{selectedP.paramValue.toLocaleString()}</span></div>
                          <input type="range" min={progData.minParam} max={progData.maxParam} step={1} value={selectedP.paramValue} onChange={(e) => handleUpdateProgramParams(index, 'paramValue', Number(e.target.value))} className="w-full h-2.5 bg-slate-200 rounded-lg appearance-none cursor-pointer" style={{ accentColor: progData.color }} />
                           <div className="flex justify-between text-xs text-slate-400 mt-1 font-medium"><span>{progData.minParam.toLocaleString()}</span><span>{progData.maxParam.toLocaleString()}</span></div>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </div>

        {isFormValid && (
          <div className="bg-gradient-to-r from-blue-50 to-indigo-50 p-6 rounded-2xl shadow-sm border border-blue-100 mb-6">
            <h3 className="text-lg font-bold text-blue-900 mb-2 flex items-center gap-2"><Sparkles className="w-5 h-5 text-blue-600" />חוות דעת תכנונית (AI)</h3>
            <p className="text-sm text-slate-600 mb-4">רגע לפני ההגשה, קבל ניתוח אסטרטגי מהיר מבוסס בינה מלאכותית על הבחירות שעשית עבור העיר שלך.</p>
            {aiFeedback ? (
              <div className="bg-white p-4 rounded-xl text-sm text-slate-700 leading-relaxed border border-blue-100 shadow-sm whitespace-pre-wrap font-medium">{aiFeedback}</div>
            ) : (
              <button onClick={handleGenerateAiFeedback} disabled={isGeneratingAi} className="w-full py-3 rounded-xl font-bold text-sm bg-white border-2 border-blue-200 text-blue-700 hover:bg-blue-50 hover:border-blue-300 transition flex justify-center items-center gap-2 shadow-sm disabled:opacity-50">
                {isGeneratingAi ? <Loader2 className="w-5 h-5 animate-spin" /> : <Sparkles className="w-5 h-5" />}
                {isGeneratingAi ? 'מנתח נתונים...' : '✨ קבל חוות דעת תכנונית מותאמת אישית'}
              </button>
            )}
          </div>
        )}

        <button onClick={onSubmit} disabled={!isFormValid} className={`w-full py-5 rounded-xl font-bold text-xl transition flex justify-center items-center gap-2 shadow-lg ${!isFormValid && 'opacity-50 cursor-not-allowed'}`} style={{ backgroundColor: isFormValid ? appConfig.primaryColor : '#cbd5e1', color: isFormValid ? 'white' : '#64748b' }}>
          {isFormValid ? 'אישור ושליחת הסקר' : 'אנא מלא את כל השדות ומקם על המפה'}
        </button>
      </div>

      {/* Left Column: Map */}
      <div className="w-full lg:w-7/12 h-[50vh] lg:h-[calc(100vh-120px)] lg:sticky lg:top-24 rounded-2xl overflow-hidden shadow-lg border-4 border-white relative z-10 flex-shrink-0">
        {!surveyData.cityId && (
          <div className="absolute inset-0 bg-white/80 backdrop-blur-sm z-[1000] flex flex-col items-center justify-center text-center p-8">
            <MapIcon className="w-20 h-20 text-slate-300 mb-6" />
            <h3 className="text-2xl font-bold text-slate-800 mb-2">בחר רשות מקומית</h3>
            <p className="text-slate-500 max-w-sm">המפה תתמקד אוטומטית ביישוב שלך לאחר הבחירה, ותוכל להתחיל למקם את הפרוגרמות השונות במרחב.</p>
          </div>
        )}
        <LeafletMap 
          centerLat={mapCenterLat} centerLng={mapCenterLng} zoom={surveyData.cityId ? 13 : 9} 
          onClick={handleMapClick} interactiveCursor={activeRank !== null}
          markers={surveyData.selectedPrograms.map((p, idx) => {
            if (!p.lat) return null;
            const prog = programs.find(pr => pr.id === p.programId);
            return { lat: p.lat, lng: p.lng, rank: idx + 1, radius: p.areaSqm ? Math.sqrt(p.areaSqm / Math.PI) : 100, name: prog?.name, color: prog?.color || appConfig.primaryColor };
          }).filter(Boolean)}
          pois={pois}
        />
        
        {activeRank !== null && (
          <div className="absolute top-4 right-4 z-[1000] text-white px-5 py-3 rounded-xl shadow-2xl font-bold flex flex-col gap-1 border-2 border-white/20 animate-pulse" style={{ backgroundColor: programs.find(p => p.id === surveyData.selectedPrograms[activeRank].programId)?.color || appConfig.primaryColor }}>
            <div className="flex items-center gap-3 text-lg"><MapPin className="w-6 h-6" /> לחץ על המפה לנעיצת עדיפות {activeRank + 1} <button onClick={() => setActiveRank(null)} className="mr-6 hover:bg-black/20 p-1.5 rounded-full transition"><X className="w-5 h-5" /></button></div>
          </div>
        )}

        {activeRank !== null && loadedCategoriesDisplay && (
          <div className="absolute bottom-6 left-1/2 transform -translate-x-1/2 z-[1000] bg-white/95 backdrop-blur shadow-xl rounded-full px-5 py-2.5 flex items-center gap-3 border border-slate-200 whitespace-nowrap">
            {isFetchingPois ? ( <><Loader2 className="w-5 h-5 text-blue-500 animate-spin" /><span className="text-sm font-bold text-slate-700">טוען נתוני רקע...</span></> ) : ( <><MapPinned className="w-5 h-5 text-emerald-500" /><span className="text-sm font-bold text-slate-700">רקע: {loadedCategoriesDisplay} ({pois.length})</span></> )}
          </div>
        )}
      </div>
    </div>
  );
}

// --- Admin Dashboard Component ---
function AdminDashboard({ appConfig, setAppConfig, cities, setCities, programs, setPrograms, responses, exportToXLSX, deleteResponse, saveSettings, tab, setTab, confirmAction }) {
  const [aiSummary, setAiSummary] = useState('');
  const [isGeneratingSummary, setIsGeneratingSummary] = useState(false);
  
  const handleUpdateCity = (id, field, value) => setCities(cities.map(c => c.id === id ? { ...c, [field]: value } : c));
  const handleUpdateProgram = (id, field, value) => setPrograms(programs.map(p => p.id === id ? { ...p, [field]: ['minArea', 'maxArea', 'minParam', 'maxParam'].includes(field) ? Number(value) : value } : p));

  const handleGenerateAiSummary = async () => {
    setIsGeneratingSummary(true);
    const dataStr = responses.map(r => {
      const cName = cities.find(c => c.id === r.cityId)?.name;
      const progs = r.selectedPrograms.map(p => programs.find(pr => pr.id === p.programId)?.name).join(', ');
      return `משיב: ${r.role} מ${cName}. בחירות: ${progs}`;
    }).join('\n');

    let prompt = `לפניך נתונים של סקר מנהיגים מקומיים בנוגע לתכנון שדה תעופה בנגב. הנתונים:\n${dataStr}\n\nאנא ספק "דוח מנהלים" קצר הכולל:\n1. מגמות בולטות בבחירת הפרוגרמות.\n2. תובנה אסטרטגית מעניינת שעולה מהנתונים.`;
    if (responses.length === 0) prompt = "כתוב הודעה שאין עדיין מספיק נתונים בסקר כדי לייצר דוח מנהלים סטטיסטי משמעותי.";
    
    const response = await generateWithGemini(prompt);
    setAiSummary(response);
    setIsGeneratingSummary(false);
  };

  return (
    <div className="bg-white rounded-3xl shadow-lg border border-slate-100 overflow-hidden min-h-[750px] flex flex-col md:flex-row">
      <div className="w-full md:w-64 text-white p-6 flex flex-col gap-3 shrink-0" style={{ backgroundColor: '#0f172a' }}>
        <h2 className="text-xl font-bold mb-6 mt-2 px-2 text-white/80">פאנל ניהול</h2>
        
        <button onClick={() => setTab('summary')} className={`flex items-center gap-3 px-4 py-3 rounded-xl transition text-right font-medium ${tab === 'summary' ? 'bg-white/20 shadow-inner' : 'hover:bg-white/10'}`}><BarChart2 className="w-5 h-5" /> סיכום תשובות ({responses.length})</button>
        <button onClick={() => setTab('map')} className={`flex items-center gap-3 px-4 py-3 rounded-xl transition text-right font-medium ${tab === 'map' ? 'bg-white/20 shadow-inner' : 'hover:bg-white/10'}`}><MapIcon className="w-5 h-5" /> מפה מתכללת</button>
        <button onClick={() => setTab('cities')} className={`flex items-center gap-3 px-4 py-3 rounded-xl transition text-right font-medium ${tab === 'cities' ? 'bg-white/20 shadow-inner' : 'hover:bg-white/10'}`}><MapPin className="w-5 h-5" /> ניהול יישובים</button>
